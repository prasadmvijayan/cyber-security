<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/family_themed_page_chip_selected_color" />
            <corners android:radius="@dimen/thing_theme_dimen_c1_1" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/transparent" />
            <corners android:radius="@dimen/thing_theme_dimen_c1_1" />
            <stroke android:width="1.0px" android:color="@color/family_themed_page_divider_color" />
        </shape>
    </item>
</selector>