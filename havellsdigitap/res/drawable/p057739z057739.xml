<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="@dimen/thing_dp_8" />
            <solid android:color="?camera_item_progress_horizontal_bg" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/thing_dp_8" />
                <gradient android:startColor="?camera_item_progress_horizontal_start" android:endColor="?camera_item_progress_horizontal_end" android:angle="0.0" />
            </shape>
        </scale>
    </item>
</layer-list>