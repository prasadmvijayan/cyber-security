        <shape>
            <gradient android:startColor="#b3ffffff" android:endColor="@color/white" android:angle="0.0" />
            <corners android:bottomLeftRadius="@dimen/thing_dp_12" android:bottomRightRadius="@dimen/thing_dp_12" />
