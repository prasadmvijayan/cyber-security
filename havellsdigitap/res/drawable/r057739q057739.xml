<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="0.0dip" />
            <gradient android:startColor="@color/upgrade_progress_default" android:endColor="@color/upgrade_progress_default" android:angle="270.0" android:centerY="0.0" android:centerColor="@color/upgrade_progress_default" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="0.0dip" />
                <gradient android:startColor="@color/upgrade_progress_loading" android:endColor="@color/upgrade_progress_loading" android:angle="270.0" android:centerY="0.0" android:centerColor="@color/upgrade_progress_loading" />
            </shape>
        </clip>
    </item>
</layer-list>