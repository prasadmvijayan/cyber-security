<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#0d000000" />
            <corners android:bottomLeftRadius="@dimen/thing_dp_12" android:bottomRightRadius="@dimen/thing_dp_12" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient android:startColor="#b3ffffff" android:endColor="@color/white" android:angle="0.0" />
                <corners android:topRightRadius="@dimen/thing_dp_7" android:bottomLeftRadius="@dimen/thing_dp_12" android:bottomRightRadius="@dimen/thing_dp_7" />
            </shape>
        </clip>
    </item>
</layer-list>