<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <ripple android:color="?android:colorControlHighlight">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/white_f8f9fa" />
                    <stroke android:width="2.0dip" android:color="@color/white_9ea7ac" android:dashWidth="5.0dip" android:dashGap="6.0dip" />
                    <padding android:left="7.0dip" android:top="7.0dip" android:right="7.0dip" android:bottom="7.0dip" />
                    <corners android:radius="@dimen/size_50" />
                </shape>
            </item>
        </ripple>
    </item>
    <item android:state_enabled="false">
        <ripple android:color="?android:colorControlHighlight">
            <item>
                <shape>
                    <stroke android:width="5.0dip" android:color="@color/white_9ea7ac" android:dashWidth="5.0dip" android:dashGap="5.0dip" />
                    <padding android:left="7.0dip" android:top="7.0dip" android:right="7.0dip" android:bottom="7.0dip" />
                    <corners android:radius="2.0dip" />
                    <solid android:color="@color/white_f8f9fa" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>